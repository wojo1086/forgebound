# Supabase project credentials
# Get these from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# JWT JWK (ES256 public key for verifying Supabase tokens)
# Get this from: https://supabase.com/dashboard → your project → Settings → API → JWT Settings
SUPABASE_JWT_JWK={"x":"...","y":"...","alg":"ES256","crv":"P-256","ext":true,"kid":"...","kty":"EC","key_ops":["verify"]}

# Direct database connection (used for table creation/migrations on startup)
# Get this from: https://supabase.com/dashboard → your project → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres"
